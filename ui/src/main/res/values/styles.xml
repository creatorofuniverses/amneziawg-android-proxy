<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="AmneziaWgTheme.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextAppearance">@style/TextAppearance.Awg.Title</item>
    </style>

    <style name="AppThemeBase" parent="AmneziaWgTheme">
        <item name="materialCardViewStyle">@style/AmneziaWgTheme.MaterialCardView</item>
        <item name="toolbarStyle">@style/AmneziaWgTheme.Toolbar</item>
        <item name="bottomSheetDialogTheme">@style/AmneziaWgTheme.BottomSheetDialog</item>
        <item name="android:statusBarColor">@null</item>
        <!-- Visual refresh: outlined inputs app-wide + colorOnSurface input text
             (fixes the black-on-black editor bug). -->
        <item name="textInputStyle">@style/AmneziaWgTheme.TextInputLayout</item>
        <!-- Selection mode: distinct primaryContainer contextual bar + back close icon. -->
        <item name="actionModeStyle">@style/AmneziaWgTheme.ActionMode</item>
        <item name="actionModeCloseDrawable">@drawable/ic_arrow_back</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="preferenceTheme">@style/Awg.PreferenceThemeOverlay</item>
        <!-- Visual refresh: calm tonal snackbars app-wide (import/create/delete messages). -->
        <item name="snackbarStyle">@style/Widget.Awg.Snackbar</item>
        <item name="snackbarTextViewStyle">@style/Widget.Awg.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/Widget.Awg.Snackbar.Button</item>
    </style>

    <!-- Selection-mode top bar: primaryContainer so it reads as a distinct mode. -->
    <style name="AmneziaWgTheme.ActionMode" parent="Widget.Material3.ActionMode">
        <item name="background">?attr/colorPrimaryContainer</item>
        <item name="titleTextStyle">@style/AmneziaWgTheme.ActionMode.Title</item>
    </style>
    <style name="AmneziaWgTheme.ActionMode.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
    </style>

    <!-- Various additional API-specific features in values-v*/styles.xml -->
    <style name="AppTheme" parent="AppThemeBase" />

    <!-- SettingsActivity supplies its own MaterialToolbar via setSupportActionBar,
         so it must NOT also receive the decor action bar from the Material3 parent
         (that combination throws IllegalStateException on create). Scope the
         no-action-bar flags here so MainActivity keeps its decor action bar. -->
    <style name="AppTheme.Settings" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Visual refresh: bump radius 4->16dp, padding 8->16dp, flat tonal surface. -->
    <style name="AmneziaWgTheme.MaterialCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cornerRadius">@dimen/radius_card</item>
        <item name="contentPadding">@dimen/card_padding</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainer</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Visual refresh: dormant styles, applied in layouts during phase 2. -->
    <style name="AmneziaWgTheme.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="tint">?attr/colorOnPrimary</item>
        <item name="elevation">@dimen/elevation_fab</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Awg.Fab</item>
    </style>
    <style name="ShapeAppearance.Awg.Fab" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_fab</item>
    </style>

    <!-- Editor toolbar Save button. Default Material button is a full-radius pill;
         override the shape to a rounded RECTANGLE (radius_input = 12dp). -->
    <style name="AmneziaWgTheme.Button.Save" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textAppearance">@style/TextAppearance.Awg.Button</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Awg.Button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
    </style>
    <style name="ShapeAppearance.Awg.Button" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_input</item>
    </style>

    <style name="AmneziaWgTheme.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/awg_switch_thumb</item>
        <item name="trackTint">@color/awg_switch_track</item>
    </style>

    <style name="AmneziaWgTheme.SectionHeader" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="AmneziaWgTheme.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_input</item>
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <!-- Route child inputs through an overlay that forces high-contrast text. -->
        <item name="materialThemeOverlay">@style/ThemeOverlay.AmneziaWgTheme.TextInput</item>
    </style>
    <style name="ThemeOverlay.AmneziaWgTheme.TextInput" parent="">
        <item name="editTextStyle">@style/AmneziaWgTheme.TextInputEditText</item>
    </style>
    <!-- editText text color = colorOnSurface fixes the black-on-black editor bug. -->
    <style name="AmneziaWgTheme.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AmneziaWgTheme.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/AmneziaWgTheme.BottomSheet</item>
    </style>

    <!-- Visual refresh: rounded 26dp top + tonal container background. -->
    <style name="AmneziaWgTheme.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Awg.BottomSheet</item>
        <item name="backgroundTint">?attr/colorSurfaceContainer</item>
    </style>
    <style name="ShapeAppearance.Awg.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_sheet_top</item>
        <item name="cornerSizeTopRight">@dimen/radius_sheet_top</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="NoBackgroundTheme" parent="AppTheme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="colorPrimaryDark">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="TvTheme" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- App icon shape: 9dp rounded corners for the split-tunnel row (Task 8). -->
    <style name="ShapeAppearance.Awg.AppIcon" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">9dp</item>
    </style>

    <!-- Segmented Include/Exclude toggle buttons with filled checked state. -->
    <style name="Widget.Awg.SegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/segmented_button_text</item>
        <item name="backgroundTint">@color/segmented_button_bg</item>
    </style>

    <!-- Compact variant for the 3-way theme picker: trims the default button
         padding, icon padding and letter spacing so icon + label fit each
         narrow segment without ellipsizing. -->
    <style name="Widget.Awg.SegmentedButton.Compact">
        <item name="android:minWidth">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingLeft">6dp</item>
        <item name="android:paddingRight">6dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="iconPadding">5dp</item>
    </style>

    <!-- Full-screen dialog theme for the Split-tunnel panel (Task 8). -->
    <style name="ThemeOverlay_Awg_FullScreenDialog" parent="AppTheme">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>
</resources>
