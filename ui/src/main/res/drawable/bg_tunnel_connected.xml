<?xml version="1.0" encoding="utf-8"?>
<!-- Connected/ACTIVE tunnel row. Distinct from the multi-select "selected"
     state (which uses secondaryContainer + colorPrimary stroke).
     Colors resolve per theme: see awg_connected_* in values / values-night. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/awg_connected_fill" />
    <corners android:radius="@dimen/radius_list_row" />
    <stroke android:width="1.5dp" android:color="@color/awg_connected_stroke" />
</shape>
