<?xml version="1.0" encoding="utf-8"?>
<!-- Set as the app-row checkbox's android:button (or an ImageView src toggled in
     code). Replaces the default Material CheckBox look with the render's square. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:drawable="@drawable/ic_check_box_checked" />
    <item android:drawable="@drawable/ic_check_box_unchecked" />
</selector>
