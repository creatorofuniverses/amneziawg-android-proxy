<?xml version="1.0" encoding="utf-8"?>
<!-- Duplicate-config "already added" card on the paste-string screen (SPEC §C1).
     Soft, low-emphasis error surface — NOT the loud errorContainer. Resolves
     per theme via awg_dup_card_* in colors.xml / values-night/colors.xml. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/awg_dup_card_fill" />
    <corners android:radius="@dimen/radius_input" />
    <stroke android:width="1dp" android:color="@color/awg_dup_card_stroke" />
</shape>
