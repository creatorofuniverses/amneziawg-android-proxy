<?xml version="1.0" encoding="utf-8"?>
<!-- Live throughput strip for a connected tunnel row. <include>d by
     tunnel_list_item.xml. The binding adapter on the root shows it only when
     state == UP and updates rates from the per-tunnel statistics, which refresh
     themselves via ObservableTunnel's opportunistic getter (~1s). Non-focusable
     so TV d-pad skips it (focus stays on the row). -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="tunnel"
            type="org.amnezia.awg.model.ObservableTunnel" />
    </data>

    <LinearLayout
        android:id="@+id/tunnel_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:layout_marginTop="@dimen/space_md"
        android:paddingTop="@dimen/space_md"
        android:visibility="gone"
        app:statsKey="@{tunnel.name}"
        app:statsState="@{tunnel.state}"
        app:statsValue="@{tunnel.statistics}"
        tools:visibility="visible">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="@dimen/space_md"
            android:background="?attr/colorOutlineVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_download"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/stat_download"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Awg.Mono.Accent"
                    tools:text="1.2 MB/s" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_upload"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/stat_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Awg.Mono.Accent"
                    tools:text="340 KB/s" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_handshake"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/stat_handshake"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Awg.Mono"
                    tools:text="23s ago" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</layout>
