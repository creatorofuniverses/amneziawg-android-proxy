<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="@string/paste_title" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                android:text="@string/paste_hint"
                android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/paste_field_label"
                android:textAllCaps="true"
                android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/string_input_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:endIconDrawable="@drawable/ic_paste"
                app:endIconMode="custom"
                app:endIconContentDescription="@string/paste_from_clipboard">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/string_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/jetbrains_mono_family"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textAppearance="@style/TextAppearance.Awg.Mono" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/paste_clipboard_button"
                style="@style/Widget.Awg.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/paste_from_clipboard"
                app:icon="@drawable/ic_paste" />

            <TextView
                android:id="@+id/validation_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:drawablePadding="@dimen/space_sm"
                android:gravity="center_vertical"
                android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                android:visibility="gone"
                tools:ignore="MissingPrefix" />

            <!-- Duplicate-config soft card (visible only on a content duplicate) -->
            <!-- "Already added" soft card (SPEC §C1): tinted surface, NOT errorContainer. -->
            <LinearLayout
                android:id="@+id/dup_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="vertical"
                android:background="@drawable/bg_dup_card"
                android:paddingHorizontal="13dp"
                android:paddingVertical="@dimen/space_md"
                android:visibility="gone">
                <TextView
                    android:id="@+id/dup_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.4"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurface" />
                <!-- "Open <name>  →" — teal text link, single line, ic_arrow_forward trailing -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dup_open"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:singleLine="true"
                    android:textColor="?attr/colorPrimary"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconGravity="textEnd"
                    app:iconSize="15dp"
                    app:iconTint="?attr/colorPrimary" />
            </LinearLayout>

            <!-- Editable tunnel name (rename-on-import); hidden until a valid decode -->
            <TextView
                android:id="@+id/name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:text="@string/paste_name_label"
                android:textAllCaps="true"
                android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                android:textColor="?attr/colorPrimary"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/name_layout"
                style="@style/AmneziaWgTheme.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:visibility="gone"
                app:boxCornerRadiusBottomEnd="@dimen/radius_input"
                app:boxCornerRadiusBottomStart="@dimen/radius_input"
                app:boxCornerRadiusTopEnd="@dimen/radius_input"
                app:boxCornerRadiusTopStart="@dimen/radius_input"
                app:endIconDrawable="@drawable/ic_edit"
                app:endIconMode="custom"
                app:errorIconDrawable="@drawable/ic_error">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="text|textNoSuggestions|textVisiblePassword"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Awg.FieldValue" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/name_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="@string/paste_name_hint"
                android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

            <!-- Decoded preview (visible only when valid) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="13dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_md"
                        android:text="@string/paste_preview"
                        android:textAllCaps="true"
                        android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                        android:textColor="?attr/colorPrimary" />
                    <TextView
                        android:id="@+id/preview_endpoint_label"
                        style="@style/TextAppearance.Awg.FieldLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/paste_preview_endpoint"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/preview_endpoint"
                        style="@style/TextAppearance.Awg.Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_sm" />
                    <TextView
                        android:id="@+id/preview_obfuscation_label"
                        style="@style/TextAppearance.Awg.FieldLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/paste_preview_obfuscation"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/preview_obfuscation"
                        style="@style/TextAppearance.Awg.FieldValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trust warning (repeat) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_warning_triangle"
                    app:tint="@color/tunnel_status_connecting" />
                <TextView
                    android:id="@+id/trust_warning_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/add_trust_warning"
                    android:textAppearance="@style/TextAppearance.Awg.FieldLabel"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Pinned Add button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_button"
        style="@style/AmneziaWgTheme.Button.Save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/space_lg"
        android:enabled="false"
        android:text="@string/paste_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
